{
  "functions": {
    "api/generate-questions.ts": {
      "maxDuration": 300
    },
    "api/ai-mentor.ts": {
      "maxDuration": 120
    }
  },
  "crons": [
    {
      "path": "/api/cron-daily",
      "schedule": "0 18 * * *"
    },
    {
      "path": "/api/cron-leagues",
      "schedule": "10 23 * * 0"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, must-revalidate"
        }
      ]
    }
  ]
}
