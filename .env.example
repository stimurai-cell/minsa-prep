VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_GEMINI_API_KEY=
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
VITE_FIREBASE_VAPID_KEY=

# Web Push VAPID Keys (geradas com: npx web-push generate-vapid-keys --json)
VITE_VAPID_PUBLIC_KEY=
VITE_FIREBASE_VAPID_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=

# Supabase Service Role Key (para o backend API — NÃO expor ao frontend)
# Obtém em: Supabase Dashboard > Project Settings > API > service_role key
# IMPORTANTE: Nunca comitar chaves reais. Use apenas como exemplo.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Firebase Admin SDK Private Key
FIREBASE_PRIVATE_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# Credenciais opcionais para manutencao do banco via CLI/psql
SUPABASE_PROJECT_REF=
SUPABASE_ACCESS_TOKEN=
SUPABASE_DB_PASSWORD=
DATABASE_URL=

# Conta de teste para fluxos E2E manuais/assistidos
E2E_BASE_URL=https://minsa-prep.vercel.app
E2E_EMAIL=
E2E_PASSWORD=
